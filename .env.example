# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here

# Optional: Add a test Discord server (Guild) ID to register slash commands instantly on that server.
# If left blank, commands will register globally, which can take up to an hour to cache.
GUILD_ID=

# Optional: Spotify API credentials (only needed for accessing private Spotify playlists or increasing rate limits).
# If left blank, play-dl will use a public guest token which is sufficient for most users.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
